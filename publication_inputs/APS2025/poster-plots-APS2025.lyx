\begin_layout Standard
Reference parameters:
\begin_inset Formula 
\[
n_{\mathrm{ref}}=10^{19}m^{-3};\,T_{\mathrm{ref}}=100eV;\,L_{\mathrm{ref}}=10m;\,m_{\mathrm{ref}}=m_{D}\approx3.3\times10^{-27}kg;\,B_{\mathrm{ref}}=1T
\]

\end_inset

Derived reference parameters:
\begin_inset Formula 
\[
c_{\mathrm{ref}}=\sqrt{\frac{T_{\mathrm{ref}}}{m_{\mathrm{ref}}}}\approx6.9\times10^{4}m/s;\,t_{\mathrm{ref}}=\frac{L_{\mathrm{ref}}}{c_{\mathrm{ref}}}=1.4\times10^{-4}s;\,\nu_{\mathrm{ref}}=\frac{1}{t_{\mathrm{ref}}}\approx6.9\times10^{3}Hz
\]

\end_inset


\end_layout

\begin_layout Subsection
Simulation model setup
\end_layout

\begin_layout Itemize
Boltzmann electrons
\end_layout

\begin_layout Itemize
\begin_inset Quotes els
\end_inset

full-f
\begin_inset Quotes ers
\end_inset

,
 2D1V ions - no moment-kinetics in these simulations,
 because radial diffusion only implemented for 
\begin_inset Quotes els
\end_inset

full-f
\begin_inset Quotes ers
\end_inset

.
\end_layout

\begin_layout Itemize
Krook collision operator.
 Collision frequency is Braginskii's ion-ion collision frequency,
 evaluated with local density and temperature.
\end_layout

\begin_layout Subsection
Domain/grid
\end_layout

\begin_layout Itemize
10m parallel length,
 1m vertical height,
 1cm radial width
\end_layout

\begin_layout Itemize
sheath-edge boundary conditions at top/bottom
\end_layout

\begin_layout Itemize
periodic radial boundary conditions
\end_layout

\begin_layout Itemize
Compressed grid (in 
\begin_inset Formula $z$
\end_inset

) near the targets.
 Velocity space grid is coarser at large 
\begin_inset Formula $v_{\|}$
\end_inset

 to allow a large 
\begin_inset Formula $v_{\|,\mathrm{max}}=20c_{\mathrm{ref}}$
\end_inset

 without having too many grid points where the distribution function is very small.
 [This coarsened 
\begin_inset Formula $v_{\|}$
\end_inset

 grid is mostly implemented/used because in moment-kinetic simulations it would make the CFL limit less strict - I just forgot to switch to a uniform grid for these full-f simulation,
 but I don't think it causes a problem.]
\end_layout

\begin_layout Itemize
All simulations use:
\end_layout

\begin_deeper
\begin_layout Itemize
16 elements in 
\begin_inset Formula $z$
\end_inset

,
 with 
\begin_inset Formula $\mathtt{ngrid}=5$
\end_inset

 (4th order polynomials)
\end_layout

\begin_layout Itemize
15 elements in 
\begin_inset Formula $v_{\parallel}$
\end_inset

,
 with 
\begin_inset Formula $\mathtt{ngrid}=6$
\end_inset

 (5th order polynomials) [this choice means there is no grid point at 
\begin_inset Formula $v_{\parallel}=0$
\end_inset

 - it is the middle of an element,
 and each element contains an even number of grid points]
\end_layout

\end_deeper
\begin_layout Itemize
Radial resolution for 2D simulations is varied as described in the results.
\end_layout

