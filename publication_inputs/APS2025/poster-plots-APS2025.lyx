\begin_layout Subsubsection
Effect of radial dissipation
\end_layout

\begin_layout Standard
Adding radial dissipation in the form of diffusion
\begin_inset Formula 
\[
\frac{\partial f}{\partial t}=\ldots+D_{r}\frac{\partial^{2}f}{\partial r^{2}}
\]

\end_inset

can entirely stabilise the instability.
\end_layout

\begin_layout Standard
Values of 
\begin_inset Formula $D_{r}$
\end_inset

 are reported in dimensionless form below.
 To get values in 
\begin_inset Formula $m^{2}/s$
\end_inset

 multiply by 
\begin_inset Formula $L_{\mathrm{ref}}c_{\mathrm{ref}}=6.9\times10^{5}m^{2}/s$
\end_inset

.
\end_layout

\begin_layout Standard
For comparison classical particle diffusivity 
\begin_inset Formula $D_{\mathrm{classical}}=\rho_{e}^{2}\nu_{ei}$
\end_inset

 and classical heat diffusivity 
\begin_inset Formula $\chi_{i,\mathrm{classical}}=\rho_{i}^{2}\nu_{ii}$
\end_inset

 (calculated using 
\begin_inset Formula $T_{i\parallel}$
\end_inset

 in place of 
\begin_inset Formula $T_{i}$
\end_inset

 because these are 1V simulations),
 evaluated using the background parameters,
 are around 
\begin_inset Formula $D_{\mathrm{classical}}=3.5\times10^{-9}L_{\mathrm{ref}}c_{\mathrm{ref}}\approx2.4\times10^{-3}m^{2}/s$
\end_inset

 and 
\begin_inset Formula $\chi_{i,\mathrm{classical}}=4.8\times10^{-8}L_{\mathrm{ref}}c_{\mathrm{ref}}\approx3.3\times10^{-2}m^{2}/s$
\end_inset

 (see plots below).
 Also 
\begin_inset Formula $\rho_{i}=9\times10^{-5}L_{\mathrm{ref}}=0.9mm$
\end_inset

 is around 1/10th of the radial box width (which is 
\begin_inset Formula $10^{-3}L_{\mathrm{ref}}=1cm$
\end_inset

).
\end_layout

